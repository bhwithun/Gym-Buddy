<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/item_border"
        android:padding="0dp"
        android:clipChildren="true"
        android:clipToOutline="true">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/verticalGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/titleContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#F9F72E"
                android:background="#4DA4278D"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/helpIcon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="Bench Press" />

            <ImageView
                android:id="@+id/helpIcon"
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:src="@android:drawable/ic_menu_help"
                android:background="#4DA4278D"
                android:backgroundTint="@null"
                android:padding="8dp"
                android:contentDescription="Search exercise online"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/weightLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFF00"
            android:layout_marginTop="16dp"
            android:gravity="left"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/titleContainer"
            tools:text="Weight:" />

        <TextView
            android:id="@+id/weightValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#FFFF00"
            android:gravity="center"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/weightLabel"
            tools:text="45" />

        <TextView
            android:id="@+id/repsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#00FFFF"
            android:layout_marginTop="16dp"
            android:gravity="left"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/weightValue"
            tools:text="Reps:" />

        <TextView
            android:id="@+id/repsValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#00FFFF"
            android:gravity="center"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/repsLabel"
            tools:text="8" />

        <TextView
            android:id="@+id/setsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#00FF00"
            android:layout_marginTop="16dp"
            android:gravity="left"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/repsValue"
            tools:text="Sets:" />

        <TextView
            android:id="@+id/setsValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#00FF00"
            android:gravity="center"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/setsLabel"
            tools:text="4" />

        <TextView
            android:id="@+id/cooldownLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF6B6B"
            android:layout_marginTop="16dp"
            android:gravity="left"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/setsValue"
            tools:text="Cooldown:" />

        <TextView
            android:id="@+id/cooldownValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#FF6B6B"
            android:fontFamily="@font/seven_segment"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/verticalGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cooldownLabel"
            tools:text=":59" />

        <TextView
            android:id="@+id/difficultyLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Difficulty"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalGuideline"
            app:layout_constraintTop_toBottomOf="@+id/titleContainer"
            app:layout_constraintBottom_toTopOf="@+id/starRatingContainer" />

        <LinearLayout
            android:id="@+id/starRatingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalGuideline"
            app:layout_constraintTop_toBottomOf="@+id/difficultyLabel"
            app:layout_constraintBottom_toTopOf="@+id/progressPieChart">

            <TextView
                android:id="@+id/starEasy"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text=" "
                android:textSize="32sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/starGood"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text=" "
                android:textSize="32sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/starHard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text=" "
                android:textSize="32sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <com.gymbuddy.ProgressPieChart
            android:id="@+id/progressPieChart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginEnd="16dp"
            android:gravity="top"
            app:layout_constraintWidth_percent="0.4"
            app:layout_constraintStart_toStartOf="@+id/verticalGuideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/notesText"
            app:layout_constraintTop_toBottomOf="@+id/starRatingContainer" />

        <TextView
            android:id="@+id/notesText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="top|start"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalGuideline"
            app:layout_constraintTop_toBottomOf="@+id/progressPieChart"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="Notes: Keep elbows in" />

        <TextView
            android:id="@+id/fullScreenNotesText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/item_border"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Keep elbows in" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>